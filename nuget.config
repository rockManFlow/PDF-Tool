<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- NU1100 且连 ReferenceAssemblies 都失败时，多为本机 NuGet 源未包含 nuget.org（离线、企业策略等）。 -->
  <!-- 未使用 <clear />，以便与全局/企业 nuget.config 中的私有源合并。 -->
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
